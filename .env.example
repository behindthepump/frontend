# Firebase web app config (Project settings → Your apps in the Firebase
# console). Copy to .env.local and fill in. Used for authentication only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Backend API base URL (the Express server in ../backend).
VITE_API_URL=http://localhost:4100
